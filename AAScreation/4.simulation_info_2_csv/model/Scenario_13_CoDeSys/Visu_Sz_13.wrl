#VRML V2.0 utf8

PROTO Switch_Button [
  exposedField SFVec3f Switch_Translation 0 0 0
  exposedField SFVec3f Switch_Scale 1 1 1
  exposedField MFString Switch_Caption "Switch" 
  eventOut SFBool Switch_State 
]
{
  Transform {
    translation IS Switch_Translation
    scale IS Switch_Scale
    children [
      Transform {
        translation 0 0.2 0
        children Shape {
          geometry Cylinder {
            radius 2.2
            height 0.4
          }
          appearance Appearance {
            material Material {
              specularColor 0.39 0.39 0.39
              shininess 0.11
              diffuseColor 0.61 0.61 0.61
              ambientIntensity 0.25
            }
          }
        }
      }
      Transform {
        translation -1.5 0.1 4.6
        rotation 1 0 0 -1.5708
        children Shape {
          geometry Text {
            fontStyle FontStyle {
              style "BOLD"
              size 1.2
              family "SANS" 
            }
            string IS Switch_Caption
          }
          appearance Appearance {
            material Material {
              specularColor 0.5 0.5 0.5
              emissiveColor 0 0 0.13
              diffuseColor 0 0 0
              ambientIntensity 0
            }
          }
        }
      }
      Transform {
        scale 1 0.5 1
        children [
          DEF SwitchButton_Sensor TouchSensor {
          }
          DEF SwitchButton_Core Transform {
            translation 0 1 0
            children Shape {
              geometry Cylinder {
                radius 1.5
              }
              appearance Appearance {
                material DEF SwitchButton_Mat Material {
                  specularColor 0.5 0.5 0.5
                  emissiveColor 0 0.15 0
                  diffuseColor 0 0 0
                  ambientIntensity 0
                }
              }
            }
          }
        ]
      }
    ]
  }
  DEF SwitchButton_Script Script {
    eventIn SFBool SButton_Active 
    field SFNode Node1 USE SwitchButton_Mat
    field SFNode Node2 USE SwitchButton_Core
    eventOut SFBool state IS Switch_State
    url "vrmlscript:
	 function SButton_Active (value) {

		 if (state)
		 { 
			 if (value) {
				 Node1.diffuseColor = new SFColor (0, 0, 0);
				 Node2.translation = new SFVec3f (0, 1, 0);
				 state = FALSE;
			 }
		 }
		 else 
		 {
		  if (value) {
				 Node1.diffuseColor = new SFColor (0, 0, 0);
				 Node2.translation = new SFVec3f (0, 0, 0);		
				 state = TRUE;
			 }
		 }
		
	 }
	 " 
  }
  ROUTE SwitchButton_Sensor.isActive TO SwitchButton_Script.SButton_Active
}

PROTO SetPoint_Area [
  exposedField SFVec3f Marker_Translation 0 0 0
  exposedField SFInt32 Marker_Visible 0
  eventOut SFVec3f SetPoint_Changed 
  eventOut SFBool isActive 
]
{
  Switch {
    whichChoice IS Marker_Visible
    choice Transform {
      translation IS Marker_Translation
      children Shape {
        geometry Cone {
          height 0.1
          bottomRadius 0.05
        }
        appearance Appearance {
          material Material {
            diffuseColor 0 1 0
          }
        }
      }
    }
  }
  DEF Plane_with_Sensor Transform {
    children [
      DEF Touch_Sensor TouchSensor {
        isActive IS isActive
        hitPoint_changed IS SetPoint_Changed
      }
      Shape {
        geometry IndexedFaceSet {
          coordIndex [
            0, 1, 2, 3, -1 
          ]
          coord DEF Sensor_Coord Coordinate {
            point [
              -1 0 1,
              1 0 1,
              1 0 -1,
              -1 0 -1 
            ]
          }
        }
        appearance Appearance {
          material Material {
            transparency 0.8
            diffuseColor 0 0 1
          }
        }
      }
    ]
  }
}

PROTO Push_Button [
  exposedField MFString Button_Caption [
  "Push" 
  "Button" 
]
  exposedField SFVec3f Button_Scale 1 1 1
  exposedField SFVec3f Button_Translation 0 0 0
  eventOut SFBool Button_State 
]
{
  Transform {
    translation IS Button_Translation
    scale IS Button_Scale
    children [
      Transform {
        translation 0 0.2 0
        children Shape {
          geometry Cylinder {
            radius 2.2
            height 0.4
          }
          appearance Appearance {
            material Material {
              specularColor 0.39 0.39 0.39
              shininess 0.11
              diffuseColor 0.61 0.61 0.61
              ambientIntensity 0.25
            }
          }
        }
      }
      Transform {
        translation -1.5 0.1 4.5
        rotation 1 0 0 -1.5708
        children Shape {
          geometry Text {
            fontStyle FontStyle {
              style "BOLD"
              size 1.2
              family "SANS" 
            }
            string IS Button_Caption
          }
          appearance Appearance {
            material Material {
              specularColor 0.5 0.5 0.5
              diffuseColor 0 0 0
              ambientIntensity 0
            }
          }
        }
      }
      Transform {
        scale 1 0.5 1
        children [
          DEF PushButton_Sensor TouchSensor {
          }
          DEF PushButton_Core Transform {
            translation 0 1 0
            children Shape {
              geometry Cylinder {
                radius 1.5
              }
              appearance Appearance {
                material DEF PushButton_Mat Material {
                  specularColor 0.5 0.5 0.5
                  emissiveColor 0 0.15 0
                  diffuseColor 0 0 0
                  ambientIntensity 0
                }
              }
            }
          }
        ]
      }
    ]
  }
  DEF PushButton_Script Script {
    eventIn SFBool PButton_Active 
    field SFNode Node1 USE PushButton_Mat
    field SFNode Node2 USE PushButton_Core
    eventOut SFBool state IS Button_State
    url "vrmlscript:
	 function PButton_Active (value) {

		 if (state)
		 { 
			 Node1.diffuseColor = new SFColor (0, 0, 0);
			 Node2.translation = new SFVec3f (0, 1, 0);
			 state = FALSE;
		 }
		 else 
		 { 
			 Node1.diffuseColor = new SFColor (0.4, 0, 0);
			 Node2.translation = new SFVec3f (0, 0, 0);		
			 state = TRUE;
		 }
		
	 }
	 " 
  }
  ROUTE PushButton_Sensor.isActive TO PushButton_Script.PButton_Active
}

