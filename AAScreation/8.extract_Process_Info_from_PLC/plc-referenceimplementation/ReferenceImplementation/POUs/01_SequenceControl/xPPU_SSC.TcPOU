    <Action Name="_aTransferWPToSSCEnd_active" Id="{fa32bf10-e7a6-4344-ab87-0fb340a10bb7}">
      <Implementation>
        <ST><![CDATA[m_subRes := i_process^.Execute(
	EBehaviorType.control_primitive,
	EPrimitives.SSC_MoveWorkpieceTo_PSEnd,
	m_emptyParams);
]]></ST>
      </Implementation>
      <ObjectProperties>
        <XmlArchive>
          <Data>
            <o xml:space="preserve" t="ActionObjectDuplicationModeProperty">
              <v n="Embedded">true</v>
            </o>
          </Data>
          <TypeList>
            <Type n="ActionObjectDuplicationModeProperty">{6a58c9ae-b0e2-4127-8d9c-cbfc36a09580}</Type>
            <Type n="Boolean">System.Boolean</Type>
          </TypeList>
        </XmlArchive>
      </ObjectProperties>
    </Action>
    <Action Name="MetalDetection" Id="{15ff6fa2-94af-4ede-9a3a-4be51a167c83}">
      <Implementation>
        <ST><![CDATA[IF m_alarm_flags[1] = FALSE
	AND i_state^.GetBinary(EProcessVariables.SSC_WPMetalAtMiddle) 
THEN
    i_error^.AddMessage(EAlarms.SSC_WP_METAL, TRUE, ESeverity.error, ' WP in SSC was made up of metals');
    m_alarm_flags[1] := TRUE; 
END_IF

//new alarm
fb_SSC_AtStartFalling(CLK := i_state^.GetBinary(EProcessVariables.SSC_WPAtStart));
fb_SSC_RampFalling(CLK := i_state^.GetBinary(EProcessVariables.SSC_WPAtRampEnd));
fb_SSC_RampRising(CLK := i_state^.GetBinary(EProcessVariables.SSC_WPAtRampEnd));

IF m_alarm_flags[3] = FALSE AND fb_SSC_AtStartFalling.Q 
   AND NOT (i_state^.GetBinary(EProcessVariables.RFC_WPAtEnd))  
   AND NOT fb_SSC_RampFalling.Q  
   AND NOT fb_SSC_RampRising.Q   
THEN
	i_error^.AddMessage(EAlarms.SSC_WPNotGetRamp, TRUE, ESeverity.error, 'WP can not get SSC ramp');
   	m_alarm_flags[3] := TRUE;
END_IF
]]></ST>
      </Implementation>
    </Action>
    <Action Name="TransferWPToPSStart_active" Id="{b3acd69f-0255-4601-91c6-2ba0e00b22e5}">
      <Implementation>
        <ST><![CDATA[m_subRes := i_process^.Execute(
	EBehaviorType.control_primitive,
	EPrimitives.SSC_TransferWorkpieceTo_PSStart,
	m_emptyParams);]]></ST>
      </Implementation>
    </Action>
    <Action Name="TransferWPToRampEnd_active" Id="{51144d9b-8e79-4a05-9453-918c572208e0}">
      <Implementation>
        <ST><![CDATA[m_subRes := i_process^.Execute(
	EBehaviorType.control_primitive,
	EPrimitives.SSC_TransferWorkpieceTo_RampEnd,
	m_emptyParams);
]]></ST>
      </Implementation>
    </Action>
    <Action Name="TransferWPToRampEnd_exit" Id="{7d7f48dd-f07a-4992-85cb-262e470b1b85}">
      <Implementation>
        <ST><![CDATA[i_state^.ShiftProduct(EProducts.SSC_product1,0);

IF i_state^.GetBinary(EProcessVariables.SSC_WPAtRampEnd) THEN
   	m_timer_PresenceSensor(IN := TRUE, PT := T#1000MS);
ELSE
    m_timer_PresenceSensor(IN := FALSE); 
END_IF

IF NOT i_state^.GetBinary(EProcessVariables.SSC_WPAtRampEnd) THEN
    m_timer_PresenceSensor(IN := FALSE);
END_IF

IF m_alarm_flags[2] = FALSE
   AND m_timer_PresenceSensor.Q 
THEN
    i_error^.AddMessage(EAlarms.SSC_Ramp_full, TRUE, ESeverity.error, 'SSC Ramp is full');
    m_alarm_flags[2] := TRUE; 
	m_timer_PresenceSensor(IN := FALSE,PT := T#0MS);
END_IF

m_alarm_flags[1] := FALSE; 
m_alarm_flags[3] := FALSE; 
fb_SSC_RampFalling (CLK := FALSE);
fb_SSC_RampRising (CLK := FALSE);]]></ST>
      </Implementation>
    </Action>
    <Action Name="TransferWPToRFC_active" Id="{53025564-8a58-4c33-bc47-c1de6154343e}">
      <Implementation>
        <ST><![CDATA[m_subRes := i_process^.Execute(
	EBehaviorType.control_primitive,
	EPrimitives.SSC_TransferWorkpieceTo_RFC,
	m_emptyParams);
]]></ST>
      </Implementation>
    </Action>
    <Action Name="TransferWPToRFC_exit" Id="{f9cdcadb-df53-4921-84b7-a57c10cc748e}">
      <Implementation>
        <ST><![CDATA[i_state^.ShiftProduct(EProducts.SSC_product2, EProducts.RFC_product1);
i_state^.ShiftProduct(EProducts.SSC_product3, EProducts.RFC_product2);

m_alarm_flags[4] := FALSE; 
fb_RFC_AtStartFalling (CLK := FALSE);
fb_RFC_AtStartRising  (CLK := FALSE);


]]></ST>
      </Implementation>
    </Action>
    <Action Name="TransferWPToSSCEnd_exit" Id="{38a157b6-e752-4475-8138-fe249ef787ae}">
      <Implementation>
        <ST><![CDATA[]]></ST>
      </Implementation>
    </Action>
    <Action Name="WPAtRFCCheck" Id="{dacd71fc-85e7-41bb-969d-5a4fceb025ff}">
      <Implementation>
        <ST><![CDATA[fb_SSC_AtEndFalling(CLK := i_state^.GetBinary(EProcessVariables.SSC_WPAtEnd));
fb_RFC_AtStartFalling(CLK := i_state^.GetBinary(EProcessVariables.RFC_WPAtStart));
fb_RFC_AtStartRising(CLK := i_state^.GetBinary(EProcessVariables.RFC_WPAtStart));

IF fb_SSC_AtEndFalling.Q THEN
  m_timer_SSC_RFCStart(IN := TRUE,PT := T#2S);
END_IF

IF i_state^.GetBinary(EProcessVariables.RFC_WPAtStart) 
   OR fb_RFC_AtStartFalling.Q 
   OR fb_RFC_AtStartRising.Q 
THEN
  m_timer_SSC_RFCStart(IN := FALSE);
END_IF

m_timer_SSC_RFCStart();

IF (m_alarm_flags[4] = FALSE) 
   AND m_timer_SSC_RFCStart.Q 
THEN
  i_error^.AddMessage(EAlarms.SSC_WPNotGetRFC, TRUE, ESeverity.error,  'WP can not get RFC start');
  m_alarm_flags[4] := TRUE;
  m_timer_SSC_RFCStart(IN := TRUE,PT := T#2S);
END_IF
]]></ST>
      </Implementation>
    </Action>
