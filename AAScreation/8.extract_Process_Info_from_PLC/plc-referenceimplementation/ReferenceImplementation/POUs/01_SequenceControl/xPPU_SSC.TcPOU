<TcPlcObject Version="1.1.0.1">
  <POU Name="xPPU_SSC" Id="{4ca0c2fa-6b16-48bd-a71d-fd301fc31cc7}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK xPPU_SSC
VAR_INPUT
	i_error: POINTER TO ErrorManager;
	i_process: POINTER TO ProcessManager;
	i_state: POINTER TO StateTracker;
END_VAR
VAR
	m_emptyParams: ParameterSet;
	m_subRes: EOperationResult;
	m_alarm_flags: ARRAY [1..10] OF BOOL := [FALSE, FALSE, FALSE, FALSE, FALSE, FALSE,FALSE, FALSE, FALSE, FALSE];
	m_timer_PresenceSensor : TON;
	fb_SSC_AtStartFalling : F_TRIG;
	fb_SSC_AtEndFalling : F_TRIG;
	fb_SSC_RampFalling : F_TRIG;
	fb_SSC_RampRising : R_TRIG;
    fb_RFC_AtStartFalling  : F_TRIG ;
    fb_RFC_AtStartRising : R_TRIG;
	m_timer_SSC_RFCStart : TON;
END_VAR]]></Declaration>
